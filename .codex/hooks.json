{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "^apply_patch$",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.codex/hooks/pre-protected-file-guard.sh\"",
            "statusMessage": "Checking protected files",
            "timeout": 30
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^apply_patch$",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.codex/hooks/post-ts-lint.sh\"",
            "statusMessage": "Running oxfmt / oxlint",
            "timeout": 180
          },
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.codex/hooks/post-suppress-annotation-guard.sh\"",
            "statusMessage": "Checking suppress annotations",
            "timeout": 30
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.codex/hooks/user-prompt-secret-guard.sh\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
