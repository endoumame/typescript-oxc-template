{
  "name": "my-app",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:api": "pnpm --filter @my-app/api dev",
    "dev:web": "pnpm --filter @my-app/web dev",
    "build": "pnpm -r build",
    "build:api": "pnpm --filter @my-app/api build",
    "build:web": "pnpm --filter @my-app/web build",
    "test": "pnpm -r test",
    "test:api": "pnpm --filter @my-app/api test",
    "test:web": "pnpm --filter @my-app/web test",
    "typecheck": "pnpm -r typecheck",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint --type-aware .",
    "lint:fix": "oxlint --type-aware --fix .",
    "secretlint": "secretlint \"**/*\""
  },
  "devDependencies": {
    "@secretlint/secretlint-rule-preset-recommend": "^11.4.0",
    "lefthook": "^2.1.4",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "oxlint-tsgolint": "0.17.4",
    "secretlint": "^11.4.0"
  },
  "packageManager": "pnpm@10.30.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "lefthook"
    ]
  }
}
